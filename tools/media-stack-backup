#!/usr/bin/env zsh
# Media stack backup — hot-backups SQLite databases daily at 4am via LaunchAgent.
# Stores to NAS with 7-day rotation.
set -euo pipefail

LOG="$HOME/logs/media-stack-backup.log"
APPDATA="$HOME/srv/appdata"
NAS_MOUNT="/Volumes/media"
BACKUP_ROOT="$NAS_MOUNT/backups"
TODAY=$(date '+%Y-%m-%d')
BACKUP_DIR="$BACKUP_ROOT/$TODAY"
RETENTION_DAYS=7

is_interactive() { [[ -t 1 ]] }

log() {
  local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
  echo "$msg" >> "$LOG"
  is_interactive && gum style --foreground 244 "$msg" || true
}

log_ok() {
  local msg="[$(date '+%Y-%m-%d %H:%M:%S')] ✓ $1"
  echo "$msg" >> "$LOG"
  is_interactive && gum style --foreground 2 "$msg" || true
}

log_warn() {
  local msg="[$(date '+%Y-%m-%d %H:%M:%S')] ⚠ $1"
  echo "$msg" >> "$LOG"
  is_interactive && gum style --foreground 3 "$msg" || true
}

backup_sqlite() {
  local src="$1" name="$2"
  local dst="$BACKUP_DIR/${name}.db"
  if [[ -f "$src" ]]; then
    sqlite3 "$src" ".backup '$dst'" 2>> "$LOG"
    log_ok "$name: $(du -h "$dst" | cut -f1)"
  else
    log_warn "$name: source not found at $src"
  fi
}

# Bail if NAS not mounted
if [[ ! -d "$NAS_MOUNT/movies" ]]; then
  log_warn "NAS not mounted at $NAS_MOUNT — skipping backup"
  exit 0
fi

is_interactive && gum style --bold "Media Stack Backup" || true

mkdir -p "$BACKUP_DIR"

log "Starting SQLite hot-backups to $BACKUP_DIR"

# Hot-backup all SQLite databases (no downtime needed)
backup_sqlite "$APPDATA/radarr/radarr.db"          "radarr"
backup_sqlite "$APPDATA/sonarr/sonarr.db"           "sonarr"
backup_sqlite "$APPDATA/prowlarr/prowlarr.db"       "prowlarr"
backup_sqlite "$APPDATA/bazarr/db/bazarr.db"        "bazarr"
backup_sqlite "$APPDATA/tautulli/tautulli.db"       "tautulli"
backup_sqlite "$APPDATA/overseerr/db/db.sqlite3"    "seerr"

# Also run config backup
log "Running config backup..."
"$HOME/dev/plex/backup-configs.sh" >> "$LOG" 2>&1 || log_warn "Config backup had errors"

# Rotate old backups
log "Rotating backups older than $RETENTION_DAYS days..."
fd -t d --changed-before "${RETENTION_DAYS}d" . "$BACKUP_ROOT" --max-depth 1 --exec rm -rf {} 2>/dev/null
remaining=$(fd -t d . "$BACKUP_ROOT" --max-depth 1 | wc -l | tr -d ' ')
log_ok "Backup complete. $remaining backup(s) retained."
