#!/usr/bin/env zsh
# ONE global queue for heavy Rust builds / test suites / benchmarks.
#
# WHY THIS EXISTS
#   Several agents working in parallel each want to run a full test suite.
#   On a 10-core / 16 GB box those runs do not overlap usefully -- they
#   thrash. CPU oversubscription makes every suite slower than if it had run
#   alone, and memory is the real cliff: a single 1 GB bench here peaks near
#   7.5 GB RSS, so two heavy jobs at once means swap, and swap means suites
#   that never finish.
#
#   MEASURED 2026-07-20 on parot-core (2,269 tests): one `cargo nextest run`
#   consumed 2,930s of CPU against 323s of wall clock -- ~9x parallelism on
#   10 cores. A single suite ALREADY saturates the machine. There is no
#   headroom for a second concurrent job, so two suites do not finish sooner
#   in aggregate; they split the cores and both finish late instead of one
#   finishing early. That is the measured case for this queue existing.
#
#   This is a thin wrapper over task-spooler (`ts`), which is a real job
#   queue daemon -- FIFO ordering, a slot count, job listing, output capture.
#   The wrapper exists to pin ONE global socket (so every agent in every repo
#   shares the same queue), to fix the slot count, and to make the whole
#   thing a transparent command prefix.
#
# RELATIONSHIP TO cargo-slot -- THEY SOLVE OPPOSITE PROBLEMS, DON'T COMBINE
#   cargo-slot gives each agent its OWN target dir so agents can compile
#   CONCURRENTLY (cargo takes an exclusive lock on target/).
#   testq makes agents compile SERIALLY.
#   If jobs are serialized there is no lock to contend for, so a private
#   target dir buys nothing. Under testq, agents should SHARE one warm
#   target/. Use cargo-slot only when you have deliberately raised the slot
#   count above 1 and want those concurrent jobs to actually build in parallel.
#
# USAGE
#   testq <command...>        wait for a free slot, then run <command> here
#   testq --events <command>  same, but emit machine-readable state lines
#   testq -l | --list         show the queue (waiting / running / finished)
#   testq --watch             live-refreshing queue view
#   testq --status [label]    show a job's recorded outcome (default: most recent)
#   testq --slots [N]         show, or set, how many jobs run at once
#   testq --clear             forget finished jobs
#   testq --kill              stop the queue daemon (does not kill a running job)
#
# EXAMPLES
#   testq cargo nextest run --workspace
#   testq just test
#   testq -- cargo build --release        # `--` if the command starts with a flag
#   testq --events just test              # for Monitor / notification callers
#
# SEMANTICS
#   Blocks until a slot frees, then runs the command IN THIS PROCESS: stdout
#   and stderr stream live, the exit code is the command's own, and the job
#   inherits this shell's cwd and environment. It is a queue, not a sandbox --
#   `testq X` behaves exactly like `X`, only it waits its turn.
#
#   Because it BLOCKS, a caller with a timeout (an agent's shell tool caps at
#   10 minutes) should run it detached / in the background: the queue wait
#   plus the suite itself will routinely exceed any short timeout.
#
# HEARTBEAT
#   While waiting for a slot, a "still queued" line goes to stderr every
#   TESTQ_HEARTBEAT seconds (default 30; set 0 to disable). Without it the
#   wrapper prints one line and then goes silent for however long the queue
#   is -- which reads as a hang, and provokes callers into polling `testq -l`
#   or, worse, re-running the job.
#
# --events MODE
#   For callers that want NOTIFICATIONS rather than live output (an agent's
#   Monitor tool turns each stdout line into an event). Emits one line per
#   state transition:
#
#     QUEUED id=7 ahead=2 label=tq-1234-… slots=1
#     RUNNING id=7 waited=312s
#     DONE id=7 exit=0 elapsed=522s out=/tmp/ts-out.XXXX
#
#   TRADEOFF, on purpose: events mode submits the job DETACHED, so the
#   command's own stdout/stderr are captured to `out=` instead of streaming
#   live. You get notifications or you get streaming, not both -- Monitor
#   would otherwise interleave the job's output with the event lines and
#   every log line would become a notification. The exit code is still the
#   command's own.
#
# SLOT WEIGHTING (-N)
#   Heavy jobs (cargo nextest/test/bench/miri, just test*/bench*) request ALL
#   slots, so they still run exclusively. Everything else -- check, clippy,
#   build -- requests one slot and can overlap with other light jobs.
#
#   At the default TESTQ_SLOTS=1 this changes NOTHING: every job weighs 1 and
#   runs alone exactly as before. It only takes effect if you raise the slot
#   count, where it stops a 3-second `cargo check` from waiting behind a
#   9-minute suite for no resource reason. Override per-invocation with
#   TESTQ_WEIGHT=<n>.
#
# STATUS FILE -- GROUND TRUTH FOR THE EXIT CODE
#   Every job writes $TESTQ_STATUS_DIR/<label>.json (default
#   /tmp/testq-$UID-status), holding label, command, cwd, start/finish time and
#   the real exit_code. Read it with `testq --status`.
#
#   WHY: a pipe destroys the exit code. `cargo nextest run | tail -25` exits
#   with TAIL's status -- always 0 -- so a run with three failing tests reports
#   "completed (exit code 0)". Anything downstream that trusts `$?` is then
#   confidently wrong. The status file is written by the process that actually
#   ran the command, before any pipe can launder it, so it stays true no matter
#   what the caller wrapped around us.
#
# RE-ENTRANCY
#   A queued job runs with TESTQ_ACTIVE=1. If testq sees that set it runs the
#   command directly instead of enqueuing it. Without this, a queued `just
#   test` whose recipe itself calls testq would wait forever for the single
#   slot its own parent is holding -- a guaranteed self-deadlock at 1 slot.

emulate -L zsh
setopt no_unset pipe_fail

readonly SELF="${0:t}"

die() { print -u2 "$SELF: $*"; exit 1 }

# --- already inside a queued job: run directly, never re-enqueue -------------
# Management subcommands still work normally in here; only an actual command
# bypasses the queue. `--` must be handled explicitly, else `testq -- cargo x`
# would look like a flag, fall through, and deadlock on its parent's slot.
if [[ -n "${TESTQ_ACTIVE:-}" ]]; then
  case "${1:-}" in
    -h|--help|-l|--list|status|--status|--watch|--slots|--clear|--kill|"") ;;
    --events) shift; [[ $# -gt 0 ]] && exec "$@" ;;
    --) shift; [[ $# -gt 0 ]] && exec "$@" ;;
    *)  exec "$@" ;;
  esac
fi

command -v ts >/dev/null 2>&1 || die "task-spooler is not installed -- run: brew install task-spooler"

# ONE socket for the whole machine, independent of cwd, project or shell.
# That single fact is what makes the queue global across agents and repos.
export TS_SOCKET="${TESTQ_SOCKET:-/tmp/testq-${UID}.sock}"
export TS_MAXFINISHED="${TESTQ_MAXFINISHED:-50}"

readonly SLOTS="${TESTQ_SLOTS:-1}"
readonly HEARTBEAT="${TESTQ_HEARTBEAT:-30}"

# `ts -S` starts the daemon if it isn't up, and pins the slot count if it is.
# Both are idempotent, so this is safe to call on every invocation.
ensure_server() {
  ts -S "$SLOTS" >/dev/null 2>&1 \
    || die "could not start or reach the queue daemon at $TS_SOCKET"
}

# `ts -l` is one header line plus one line per job. BEFORE we are enqueued,
# every queued-or-running job is by definition ahead of us, so a plain count
# is correct here -- and only here.
queue_ahead() {
  ts -l 2>/dev/null | tail -n +2 | awk '$2 == "queued" || $2 == "running"' | wc -l | tr -d ' '
}

# Jobs genuinely ahead of OURS: queued-or-running with a LOWER id.
#
# WHY NOT "every unfinished job except mine": that also counts jobs submitted
# AFTER mine. Observed: job 150 running, 151 mine, 152 submitted later -- my
# wait line went "1 ahead" then "2 ahead" while only 150 was ever ahead. A
# position indicator that moves BACKWARDS makes a bounded wait read as
# unbounded, which is what provokes a caller into re-running the job.
jobs_ahead_of() {
  ts -l 2>/dev/null | tail -n +2 \
    | awk -v id="$1" '($1+0) < (id+0) && ($2 == "queued" || $2 == "running")' \
    | wc -l | tr -d ' '
}

# State of the job carrying our label. Labels render as "[label]command" in
# the Command column, so a fixed-string match on "[label]" is unambiguous.
# Empty means "not enqueued yet" -- NOT "gone"; the caller must not treat the
# two as the same or it will stop watching before the job ever appears.
state_by_label() {
  ts -l 2>/dev/null | grep -F "[$1]" | head -1 | awk '{print $2}'
}

# Our job id, once ts has accepted it. Empty until then (see above).
id_by_label() {
  ts -l 2>/dev/null | grep -F "[$1]" | head -1 | awk '{print $1}'
}

# --- status sidecar ----------------------------------------------------------
STATUS_DIR="${TESTQ_STATUS_DIR:-/tmp/testq-${UID}-status}"

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\t'/\\t}"
  print -r -- "$s"
}

# Called once at start (phase=running, exit_code null) and once at the end.
# Writing twice means an interrupted job leaves evidence it ever started,
# instead of leaving nothing and looking like it was never submitted.
write_status() {
  local phase="$1" rc="${2:-null}"
  mkdir -p "$STATUS_DIR" 2>/dev/null || return 0
  print -r -- "{
  \"label\": \"$(json_escape "$LABEL")\",
  \"phase\": \"$phase\",
  \"exit_code\": $rc,
  \"command\": \"$(json_escape "$CMD_STR")\",
  \"cwd\": \"$(json_escape "$PWD")\",
  \"started\": \"$STARTED_AT\",
  \"finished\": \"${FINISHED_AT:-}\",
  \"slots\": $SLOTS,
  \"weight\": $WEIGHT
}" > "$STATUS_DIR/$LABEL.json" 2>/dev/null || true
}

# How many slots this command should occupy. Heavy = exclusive.
# `cargo +nightly test` puts the toolchain first, so skip a leading `+`.
job_weight() {
  local -a w=("$@")
  local i base sub
  for (( i = 1; i <= $#w; i++ )); do
    base="${w[i]:t}"
    sub="${w[i+1]:-}"
    [[ "$sub" == +* ]] && sub="${w[i+2]:-}"
    case "$base" in
      cargo)
        case "$sub" in
          nextest|test|bench|miri) print -- "$SLOTS"; return ;;
        esac
        print -- 1; return ;;
      just)
        case "$sub" in
          test*|bench*) print -- "$SLOTS"; return ;;
        esac
        print -- 1; return ;;
    esac
  done
  print -- 1
}

case "${1:-}" in
  -h|--help)
    sed -n '/^# USAGE/,/^# RE-ENTRANCY/p' "$0" | sed 's/^# \?//'
    exit 0 ;;
  -l|--list|status)
    ensure_server; exec ts -l ;;
  --watch)
    ensure_server
    while :; do clear; print "queue: $TS_SOCKET  (slots: $SLOTS)"; print; ts -l; sleep 2; done ;;
  --status)
    if [[ -n "${2:-}" ]]; then
      [[ -f "$STATUS_DIR/$2.json" ]] || die "no status recorded for label '$2' (looked in $STATUS_DIR)"
      exec cat "$STATUS_DIR/$2.json"
    fi
    LATEST=$(ls -t "$STATUS_DIR"/*.json 2>/dev/null | head -1)
    [[ -n "$LATEST" ]] || die "no job has recorded status yet (looked in $STATUS_DIR)"
    print -u2 "$SELF: $LATEST"
    exec cat "$LATEST" ;;
  --slots)
    ensure_server
    if [[ -n "${2:-}" ]]; then
      ts -S "$2" || die "could not set slots to $2"
      print "$SELF: slots -> $2 (this session only; export TESTQ_SLOTS=$2 to persist)"
    else
      print "$SELF: slots = $SLOTS  (socket: $TS_SOCKET)"
    fi
    exit 0 ;;
  --clear)
    ensure_server; exec ts -C ;;
  --kill)
    ts -K 2>/dev/null && print "$SELF: queue daemon stopped" || print "$SELF: no queue daemon running"
    exit 0 ;;
esac

EVENTS=0
if [[ "${1:-}" == "--events" ]]; then EVENTS=1; shift; fi
[[ "${1:-}" == "--" ]] && shift
[[ $# -gt 0 ]] || die "nothing to run. See '$SELF --help'."

ensure_server

LABEL="tq-$$-${RANDOM}"
WEIGHT="${TESTQ_WEIGHT:-$(job_weight "$@")}"
(( WEIGHT > SLOTS )) && WEIGHT=$SLOTS
(( WEIGHT < 1 )) && WEIGHT=1
CMD_STR="${(j: :)${(qq)@}}"  # requote each arg: a record you can paste back and re-run
STARTED_AT="$(date +%Y-%m-%dT%H:%M:%S%z)"
FINISHED_AT=""

# --- events mode: detached submission, one line per state transition ---------
if (( EVENTS )); then
  id="$(TESTQ_ACTIVE=1 ts -L "$LABEL" -N "$WEIGHT" "$@")" \
    || die "could not enqueue job"
  write_status queued
  print "QUEUED id=$id ahead=$(jobs_ahead_of "$id") label=$LABEL slots=$SLOTS weight=$WEIGHT"
  t0=$SECONDS
  while [[ "$(ts -s "$id" 2>/dev/null)" == "queued" ]]; do sleep 1; done
  write_status running
  print "RUNNING id=$id waited=$((SECONDS - t0))s"
  t1=$SECONDS
  ts -w "$id" >/dev/null 2>&1
  rc=$?
  FINISHED_AT="$(date +%Y-%m-%dT%H:%M:%S%z)"
  write_status finished "$rc"
  print "DONE id=$id exit=$rc elapsed=$((SECONDS - t1))s out=$(ts -o "$id" 2>/dev/null) status=$STATUS_DIR/$LABEL.json"
  exit $rc
fi

# --- normal mode: transparent, with a heartbeat while we wait ----------------
ahead="$(queue_ahead)"
if (( ahead > 0 )); then
  print -u2 "$SELF: $ahead job(s) ahead of you; waiting for a free slot (slots: $SLOTS)..."
fi

# The heartbeat must start BEFORE the blocking `ts -nf`, so it necessarily
# starts before the job is enqueued -- hence "empty state means keep waiting".
# The parent kills it once `ts -nf` returns, so it cannot outlive the job.
HB_PID=0
if (( HEARTBEAT > 0 )) && (( ahead > 0 )); then
  (
    t0=$SECONDS
    while :; do
      sleep "$HEARTBEAT"
      st="$(state_by_label "$LABEL")"
      [[ "$st" == "running" || "$st" == "finished" ]] && exit 0
      my_id="$(id_by_label "$LABEL")"
      if [[ -n "$my_id" ]]; then ahead_now="$(jobs_ahead_of "$my_id")"; else ahead_now="?"; fi
      print -u2 "$SELF: still queued — $((SECONDS - t0))s elapsed, $ahead_now ahead (slots: $SLOTS)"
    done
  ) &
  HB_PID=$!
fi

stop_heartbeat() { (( HB_PID > 0 )) && kill "$HB_PID" 2>/dev/null; return 0 }
trap stop_heartbeat EXIT INT TERM

write_status running
print -u2 "$SELF: status file: $STATUS_DIR/$LABEL.json (real exit code, survives any pipe)"

# -n : inherit this process's stdout/stderr instead of capturing to a file
# -f : don't detach -- wait for the slot, then run right here
# Together they make the wrapper transparent: live output, real exit code,
# caller's cwd and environment.
TESTQ_ACTIVE=1 ts -nf -L "$LABEL" -N "$WEIGHT" "$@"
rc=$?
stop_heartbeat
FINISHED_AT="$(date +%Y-%m-%dT%H:%M:%S%z)"
write_status finished "$rc"
exit $rc
