#!/usr/bin/env zsh
# Peek at context files without loading them fully.
# Shows first N lines of each *-context.md file found under a directory.
# Usage: ctx-peek [directory] [lines] [--depth N]
#   (no args)   — this directory's context file only
#   ctx-peek .  — this dir + immediate children (depth 1)
#   --depth N   — explicit depth override

set -e

source "${HOME}/dotfiles/shell/gum_utils.sh" 2>/dev/null || true

depth=""
explicit_dir=false

# Parse all args: flags first, then positionals
positionals=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --depth) depth="$2"; shift 2 ;;
        *) positionals+=("$1"); shift ;;
    esac
done

dir="${positionals[1]:-.}"
lines="${positionals[2]:-12}"
[[ -n "${positionals[1]}" ]] && explicit_dir=true

# Default depth: no args = 0 (this dir only), explicit dir = 1 (dir + children)
if [[ -z "$depth" ]]; then
    if $explicit_dir; then
        depth=1
    else
        depth=0
    fi
fi

fd_args=(--no-ignore --glob '*-context.md' "$dir" --type f)
# fd max-depth: depth 0 = just this dir's file (max-depth 1), depth N = N+1
fd_args+=(--max-depth "$((depth + 1))")

context_files=("${(@f)$(fd "${fd_args[@]}" 2>/dev/null | sort)}")

if [[ ${#context_files[@]} -eq 0 || -z "${context_files[1]}" ]]; then
    gum_dim "No *-context.md files found under $dir" 2>/dev/null || echo "No *-context.md files found under $dir"
    exit 0
fi

skip_parents=()
pruned=0

is_under_skip() {
    local d="$1"
    for p in "${skip_parents[@]}"; do
        [[ "$d" == "$p/"* ]] && return 0
    done
    return 1
}

shown=0
for f in "${context_files[@]}"; do
    [[ -z "$f" ]] && continue

    # Get relative path for pruning
    relpath="${f#$dir/}"
    reldir="${relpath%/*}"

    # Prune children of SKIP parents
    if is_under_skip "$reldir"; then
        pruned=$((pruned + 1))
        continue
    fi

    # Check if this is a SKIP file — show only summary line
    line2=$(sed -n '2p' "$f")
    if [[ "$line2" == "> SKIP:"* ]]; then
        skip_parents+=("$reldir")
        shown=$((shown + 1))
        gum_info "$relpath" 2>/dev/null || echo "=== $relpath ==="
        echo "${line2#> }"
        echo ""
        continue
    fi

    shown=$((shown + 1))
    gum_info "$relpath" 2>/dev/null || echo "=== $relpath ==="
    # Print up to <!-- peek --> marker, or fall back to head -n
    peek_line=$(command grep -n '<!-- peek -->' "$f" 2>/dev/null | head -1 | cut -d: -f1)
    if [[ -n "$peek_line" ]]; then
        head -n "$((peek_line - 1))" "$f"
    else
        head -n "$lines" "$f"
        echo "..."
    fi
    echo ""
done

if [[ $pruned -gt 0 ]]; then
    gum_dim "$shown entries shown ($pruned subdirectories under SKIP parents omitted)" 2>/dev/null \
        || echo "$shown entries shown ($pruned subdirectories under SKIP parents omitted)"
else
    gum_dim "Found $shown context file(s) under $dir" 2>/dev/null || echo "Found $shown context file(s) under $dir"
fi
