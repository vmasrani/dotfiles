#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir
    while [[ -L "$source" ]]; do
        dir="$(cd -- "$(dirname -- "$source")" && pwd)"
        source="$(readlink -- "$source")"
        [[ "$source" == /* ]] || source="$dir/$source"
    done
    cd -- "$(dirname -- "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
readonly SCRIPT_DIR
readonly WORKFLOW="$SCRIPT_DIR/project-workflow"
TEMPLATE_DIR="$(cd -- "$SCRIPT_DIR/../templates" && pwd)"
readonly TEMPLATE_DIR
readonly CI_SETUP_BRANCH="chore/ci-setup"

fail() {
    gum style --foreground 196 --border double --padding '0 1' "$*" >&2
    exit 1
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || fail "Required command not found: $1"
}

repo_root() {
    git -C "$1" rev-parse --show-toplevel 2>/dev/null || fail "Not a Git repository: $1"
}

# gh resolves the repository from the working directory's git remote. Its -R flag
# takes OWNER/REPO, never a path, so every repository-scoped gh call runs here.
gh_in_repo() {
    local root="$1"
    shift
    (cd -- "$root" && gh "$@")
}

# Greenfield only: picks which starter justfile to copy. There is no tree to
# detect from yet, so ask.
choose_language() {
    local selected
    selected="$(gum choose rust python javascript)"
    [[ -n "$selected" ]] || fail "Choose a language"
    printf '%s' "$selected"
}

ensure_clean() {
    local root="$1"
    git -C "$root" diff --quiet || fail "Working tree has unstaged changes; commit or stash them first"
    git -C "$root" diff --cached --quiet || fail "Working tree has staged changes; commit or stash them first"
}

default_branch() {
    local root="$1"
    local base
    base="$(gh_in_repo "$root" repo view --json defaultBranchRef --jq .defaultBranchRef.name)"
    [[ -n "$base" && "$base" != null ]] || fail "Could not determine the default branch"
    printf '%s' "$base"
}

ensure_dev() {
    local root="$1"
    local base behind
    git -C "$root" fetch origin --prune
    if git -C "$root" show-ref --verify --quiet refs/remotes/origin/dev; then
        return
    fi
    base="$(default_branch "$root")"
    if git -C "$root" show-ref --verify --quiet refs/heads/dev; then
        # An unpublished local dev is a valid starting point only if it is not
        # already behind the default branch; publishing a stale one would give
        # every later task branch an old base.
        behind="$(git -C "$root" rev-list --count "dev..origin/$base")"
        [[ "$behind" == 0 ]] || fail "Local dev is $behind commits behind origin/$base; merge or delete it, then re-run"
        git -C "$root" push -u origin dev
        gum style --foreground 46 "Published the existing local branch dev"
        return
    fi
    git -C "$root" branch dev "origin/$base"
    git -C "$root" push -u origin dev
    gum style --foreground 46 "Created integration branch dev from origin/$base"
}

# Greenfield only. An existing project owns its justfile; the kit never writes,
# imports, or regenerates recipes in one.
copy_starter_justfile() {
    local root="$1"
    local language="$2"
    if [[ -f "$root/justfile" || -f "$root/Justfile" ]]; then
        return
    fi
    cp "$TEMPLATE_DIR/justfile.$language" "$root/justfile"
    gum style --foreground 46 "Created a starter justfile for $language"
}

new_project() {
    require_command gh
    gh auth status >/dev/null || fail "GitHub CLI is not authenticated; run gh auth login -h github.com"
    local name directory language root
    name="$(gum input --prompt 'Repository name: ' --placeholder 'my-project')"
    [[ "$name" =~ ^[[:alnum:]_.-]+$ ]] || fail "Repository name may contain letters, numbers, dots, underscores, and hyphens"
    directory="$(gum input --prompt 'Local directory: ' --value "$PWD/$name")"
    [[ ! -e "$directory" ]] || fail "Local directory already exists: $directory"
    language="$(choose_language)"
    gh repo create "sophiaconsulting/$name" --private
    gh repo clone "sophiaconsulting/$name" "$directory"
    root="$(repo_root "$directory")"
    "$WORKFLOW" init --dir "$root"
    copy_starter_justfile "$root" "$language"
    git -C "$root" add CLAUDE.md .agent-workflow .github justfile
    git -C "$root" commit -m 'add agent workflow'
    git -C "$root" branch -M main
    git -C "$root" push -u origin main
    git -C "$root" branch dev main
    git -C "$root" push -u origin dev
    "$WORKFLOW" gh-setup --dir "$root" --apply
    gum style --border rounded --border-foreground 46 --padding '1 2' \
        "Ready: $root" \
        'main and dev are protected; the starter justfile recipes are yours to edit.'
}

# Appends the two contract recipes to an existing justfile, but ONLY the ones
# that are absent, and ONLY by appending -- it never edits or deletes a line the
# project already has. Appended (not prepended) on purpose: in just the FIRST
# recipe is the default that a bare `just` runs, and hijacking that would be a
# surprising, destructive-in-spirit change. Idempotent: a second run finds both
# recipes and adds nothing.
ensure_ci_recipes() {
    local root="$1" justfile block=""
    justfile="$root/justfile"
    [[ -f "$justfile" ]] || justfile="$root/Justfile"
    [[ -f "$justfile" ]] || fail "no justfile in $root to add ci-fast/ci-deep to; create one first"
    grep -Eq '^ci-fast[ :]' "$justfile" || block+=$'ci-fast: fmt-check lint test\n'
    grep -Eq '^ci-deep[ :]' "$justfile" || block+=$'ci-deep: ci-fast\n'
    [[ -n "$block" ]] || return 0
    {
        printf '\n# ── CI contract (added by setup-project) ─────────────────────────────\n'
        # shellcheck disable=SC2016  # backticks are literal justfile-comment text
        printf '# CI runs `just ci-fast` on PRs into dev and `just ci-deep` on dev->main.\n'
        printf "# Edit these to aggregate THIS project's real recipes; they are the only\n"
        printf '# two names CI knows. Nothing else in this file was touched.\n'
        printf '%s' "$block"
    } >>"$justfile"
    gum style --foreground 46 "Appended the missing ci-fast/ci-deep recipe(s) to the justfile"
}

# True when dev already carries the workflow files and both contract recipes --
# i.e. a previous migration merged. Lets the migration short-circuit to just
# re-applying protection instead of opening a redundant PR.
already_set_up() {
    local root="$1"
    git -C "$root" cat-file -e origin/dev:.github/workflows/agent-fast.yml 2>/dev/null || return 1
    git -C "$root" show origin/dev:justfile 2>/dev/null | grep -Eq '^ci-fast[ :]' || return 1
    git -C "$root" show origin/dev:justfile 2>/dev/null | grep -Eq '^ci-deep[ :]' || return 1
    return 0
}

# Bootstraps CI on an existing repo, end to end: install files, add the missing
# recipes, commit, open a PR into dev, protect the branches, and arm GitHub
# auto-merge so the PR lands once the required checks pass.
#
# RULE EXCEPTION, SCOPED TO THIS ONE COMMAND: everywhere else the policy is
# never push to a shared branch from a script and never self-merge a PR. This
# bootstrap is the single sanctioned exception -- it is the human running their
# own one-time setup, not an agent -- and it is kept safe by two hard gates that
# are NOT relaxed: (1) a local `just ci-fast` must pass before anything is
# pushed, so a red PR is never opened; (2) merge is GitHub-native auto-merge
# behind the required checks (Secret scan + Workflow lint), so a red PR is never
# merged. Do not copy this push-and-merge shape into any other recipe.
#
# Idempotent throughout: safe to re-run after a fix or a partial run.
existing_project() {
    require_command gh
    require_command just
    local directory root repo branch orig_branch pr_url armed=yes
    directory="$(gum input --prompt 'Existing repository directory: ' --value "$PWD")"
    root="$(repo_root "$directory")"
    ensure_clean "$root"
    gh auth status >/dev/null || fail "GitHub CLI is not authenticated; run gh auth login -h github.com"
    repo="$(gh_in_repo "$root" repo view --json nameWithOwner --jq .nameWithOwner)" \
        || fail "origin must be a GitHub repository accessible through gh"
    ensure_dev "$root"

    if already_set_up "$root"; then
        gum style --foreground 46 "CI is already set up on dev; re-applying branch protection only"
        "$WORKFLOW" gh-setup --dir "$root" --repo "$repo" --apply
        return
    fi

    # Base the CI branch on the CURRENT tree, because that is what carries the
    # project's justfile -- basing it on dev would lose a justfile that only
    # exists on the checked-out branch. Require dev to be an ANCESTOR of HEAD so
    # the PR into dev is purely additive and can never revert work that is on dev
    # but not here.
    branch="$CI_SETUP_BRANCH"
    orig_branch="$(git -C "$root" symbolic-ref --quiet --short HEAD || true)"
    git -C "$root" merge-base --is-ancestor origin/dev HEAD \
        || fail "the checked-out branch is behind origin/dev; check out dev (or a branch ahead of it) and re-run"
    if git -C "$root" show-ref --verify --quiet "refs/heads/$branch"; then
        git -C "$root" checkout -q "$branch"
    else
        git -C "$root" checkout -q -b "$branch"
    fi

    "$WORKFLOW" init --dir "$root"
    ensure_ci_recipes "$root"

    # Commit BEFORE the gate so that a gate failure leaves a CLEAN tree on the
    # branch -- the user edits the recipe, commits, and re-runs without fighting
    # `ensure_clean`. The commit is local only; the gate below is what guards the
    # push.
    git -C "$root" add CLAUDE.md .agent-workflow .github justfile
    if git -C "$root" diff --cached --quiet; then
        gum style --foreground 214 "Nothing new to commit; the branch already carries the setup"
    else
        git -C "$root" commit -qm 'ci: set up agent workflow (CI SETUP)'
    fi

    # THE GATE. `just ci-fast` runs the project's own aggregate on this machine.
    # If the appended `ci-fast: fmt-check lint test` names recipes this project
    # does not have, just fails loudly here (its native "does not contain recipe"
    # message is shown) and NOTHING is pushed. This is the sanctioned exception's
    # hard floor: no red PR is ever opened.
    if ! ( cd -- "$root" && just ci-fast ); then
        fail "just ci-fast failed (see above). Edit ci-fast/ci-deep in the justfile to aggregate recipes this project actually has, commit, then re-run. Nothing was pushed."
    fi

    git -C "$root" push -q -u origin "$branch"

    pr_url="$(gh_in_repo "$root" pr list --head "$branch" --state open --json url --jq '.[0].url // empty' 2>/dev/null || true)"
    if [[ -z "$pr_url" ]]; then
        pr_url="$(gh_in_repo "$root" pr create --base dev --fill)"
    fi

    # Protect dev/main, then hand the merge to GitHub: auto-merge lands the PR
    # once the REQUIRED checks (Secret scan + Workflow lint) are green. The
    # advisory Linux build does not gate it, so this never blocks on a cold
    # build, and a real secret leak (red Secret scan) keeps the PR unmerged.
    "$WORKFLOW" gh-setup --dir "$root" --repo "$repo" --apply
    gh_in_repo "$root" repo edit --enable-auto-merge >/dev/null 2>&1 || true
    gh_in_repo "$root" pr merge "$pr_url" --squash --auto --delete-branch >/dev/null 2>&1 || armed=no

    # Return the working tree to where the user started; the branch merges and
    # deletes remotely once its checks pass.
    if [[ -n "$orig_branch" ]]; then
        git -C "$root" checkout -q "$orig_branch"
    fi

    if [[ "$armed" == yes ]]; then
        gum style --border rounded --border-foreground 46 --padding '1 2' \
            "CI set up for $repo" \
            "PR: $pr_url" \
            'Auto-merge is armed: GitHub merges it once Secret scan + Workflow lint pass.' \
            "dev and main are protected. Your tree is back on ${orig_branch:-its original branch}."
    else
        gum style --border rounded --border-foreground 214 --padding '1 2' \
            "CI set up for $repo, PR open but auto-merge NOT armed" \
            "PR: $pr_url" \
            "Enable 'Allow auto-merge' in the repo settings, or merge the PR" \
            'yourself once Secret scan + Workflow lint are green.'
    fi
}

main() {
    require_command gum
    require_command git
    require_command just
    gum style --border double --padding '1 2' --foreground 212 'Agent project setup'
    case "$(gum choose 'New private GitHub project' 'Migrate an existing GitHub project')" in
        'New private GitHub project') new_project ;;
        'Migrate an existing GitHub project') existing_project ;;
    esac
}

main "$@"
