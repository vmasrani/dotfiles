#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir
    while [[ -L "$source" ]]; do
        dir="$(cd -- "$(dirname -- "$source")" && pwd)"
        source="$(readlink -- "$source")"
        [[ "$source" == /* ]] || source="$dir/$source"
    done
    cd -- "$(dirname -- "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
readonly SCRIPT_DIR
KIT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
readonly KIT_DIR
readonly TEMPLATE_DIR="$KIT_DIR/templates"

# The CI contract is exactly what CI executes -- nothing else. Sub-recipe names
# (fmt-check, lint, test, ...) are project convention, not contract.
readonly CONTRACT_RECIPES=(ci-fast ci-deep)

usage() {
    cat <<'EOF'
Usage:
  project-workflow init --dir PATH
  project-workflow check --dir PATH
  project-workflow gh-setup --dir PATH [--repo OWNER/REPO] [--apply]

`init` creates only missing files. It never replaces an existing project file.
`check` validates the repository-local contract without running tests: the
workflow files exist and the justfile provides `ci-fast` and `ci-deep`.
`gh-setup` prints the exact gh commands by default; --apply creates labels and
applies the branch-protection settings after you have reviewed them.
EOF
}

fail() {
    printf 'project-workflow: %s\n' "$*" >&2
    exit 1
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || fail "required command not found: $1"
}

project_root() {
    git -C "$1" rev-parse --show-toplevel 2>/dev/null || fail "not a Git repository: $1"
}

# gh resolves the repository from the working directory's git remote. Its -R flag
# takes OWNER/REPO, never a path, so path-scoped gh calls run here instead.
gh_in_repo() {
    local root="$1"
    shift
    (cd -- "$root" && gh "$@")
}

copy_missing() {
    local source="$1"
    local destination="$2"
    if [[ -e "$destination" ]]; then
        printf 'kept existing %s\n' "$destination"
        return
    fi
    mkdir -p "$(dirname -- "$destination")"
    cp "$source" "$destination"
    printf 'created %s\n' "$destination"
}

ensure_policy_link() {
    local instruction_file="$1"
    local marker='# Agent workflow policy'
    if grep -Fqx "$marker" "$instruction_file" 2>/dev/null; then
        return
    fi
    # shellcheck disable=SC2016  # backticks are literal markdown, not a subshell
    printf '\n%s\nRead and follow `.agent-workflow/AGENT_WORKFLOW.md`; it defines the required Issue, worktree, PR, CI, and gh workflow for this project.\n' "$marker" >>"$instruction_file"
    printf 'added workflow policy link to %s\n' "$instruction_file"
}

init() {
    local directory=""
    while (($#)); do
        case "$1" in
            --dir) directory="${2:-}"; shift 2 ;;
            *) fail "unknown init argument: $1" ;;
        esac
    done
    [[ -n "$directory" ]] || fail "init requires --dir PATH"

    require_command git
    local root
    root="$(project_root "$directory")"
    copy_missing "$KIT_DIR/policy/AGENT_WORKFLOW.md" "$root/.agent-workflow/AGENT_WORKFLOW.md"
    copy_missing "$TEMPLATE_DIR/CLAUDE.md" "$root/CLAUDE.md"
    ensure_policy_link "$root/CLAUDE.md"
    copy_missing "$TEMPLATE_DIR/pull_request_template.md" "$root/.github/pull_request_template.md"
    copy_missing "$TEMPLATE_DIR/issue_task.md" "$root/.github/ISSUE_TEMPLATE/agent-task.md"
    copy_missing "$TEMPLATE_DIR/ci-fast.yml" "$root/.github/workflows/agent-fast.yml"
    copy_missing "$TEMPLATE_DIR/ci-deep.yml" "$root/.github/workflows/agent-deep.yml"
    printf "\nNext: add the ci-fast and ci-deep recipes, run \`project-workflow check --dir %s\`, then review the Git diff.\n" "$root"
}

has_recipe() {
    local root="$1"
    local recipe="$2"
    (cd -- "$root" && just --list --unsorted 2>/dev/null) | awk '{print $1}' | grep -Fxq "$recipe"
}

suggested_body() {
    case "$1" in
        ci-fast) printf 'ci-fast: fmt-check lint test  # aggregate your existing fast checks' ;;
        ci-deep) printf 'ci-deep: ci-fast  # plus any real integration/e2e recipes you already have' ;;
    esac
}

check() {
    local directory=""
    while (($#)); do
        case "$1" in
            --dir) directory="${2:-}"; shift 2 ;;
            *) fail "unknown check argument: $1" ;;
        esac
    done
    [[ -n "$directory" ]] || fail "check requires --dir PATH"
    require_command git
    local root
    local failed=false
    root="$(project_root "$directory")"
    local required_files=(
        "$root/CLAUDE.md"
        "$root/.agent-workflow/AGENT_WORKFLOW.md"
        "$root/.github/pull_request_template.md"
        "$root/.github/ISSUE_TEMPLATE/agent-task.md"
        "$root/.github/workflows/agent-fast.yml"
        "$root/.github/workflows/agent-deep.yml"
    )
    local file
    for file in "${required_files[@]}"; do
        if [[ -f "$file" ]]; then
            printf 'ok file %s\n' "${file#"$root"/}"
        else
            printf 'missing file %s\n' "${file#"$root"/}" >&2
            failed=true
        fi
    done
    if command -v just >/dev/null 2>&1; then
        local recipe
        for recipe in "${CONTRACT_RECIPES[@]}"; do
            if has_recipe "$root" "$recipe"; then
                printf 'ok recipe %s\n' "$recipe"
            else
                printf 'missing recipe %s; add one that aggregates this project'"'"'s own recipes, for example:\n    %s\n' \
                    "$recipe" "$(suggested_body "$recipe")" >&2
                failed=true
            fi
        done
    else
        printf 'missing command just; recipes were not inspected\n' >&2
        failed=true
    fi
    [[ "$failed" == false ]] || exit 1
}

gh_setup() {
    local directory=""
    local repository=""
    local apply=false
    while (($#)); do
        case "$1" in
            --dir) directory="${2:-}"; shift 2 ;;
            --repo) repository="${2:-}"; shift 2 ;;
            --apply) apply=true; shift ;;
            *) fail "unknown gh-setup argument: $1" ;;
        esac
    done
    [[ -n "$directory" ]] || fail "gh-setup requires --dir PATH"
    require_command git
    require_command gh
    local root
    root="$(project_root "$directory")"
    if [[ -z "$repository" ]]; then
        repository="$(gh_in_repo "$root" repo view --json nameWithOwner --jq .nameWithOwner)"
    fi
    gh auth status >/dev/null || fail "GitHub CLI is not authenticated"
    if [[ "$apply" == false ]]; then
        cat <<EOF
Review and then run:
  project-workflow gh-setup --dir $root --repo $repository --apply

This will create/update the task labels and protect dev/main. It requires both
branches to exist. Required status checks are the job names in this kit's
workflows: Project checks, Secret scan, Workflow lint, and Deep integration checks.
EOF
        return
    fi
    gh label create task --color 0E8A16 --description 'Agent-owned implementation task' --force -R "$repository"
    gh label create handoff --color 5319E7 --description 'Needs another session to continue' --force -R "$repository"
    gh label create blocked --color B60205 --description 'Blocked on an external decision or state' --force -R "$repository"
    local temporary
    temporary="$(mktemp)"
    cat >"$temporary" <<'EOF'
{"required_status_checks":{"strict":true,"contexts":["Project checks","Secret scan","Workflow lint"]},"enforce_admins":true,"required_pull_request_reviews":null,"restrictions":null,"required_linear_history":true,"allow_force_pushes":false,"allow_deletions":false,"block_creations":false,"required_conversation_resolution":true}
EOF
    gh api --method PUT "repos/$repository/branches/dev/protection" --input "$temporary"
    cat >"$temporary" <<'EOF'
{"required_status_checks":{"strict":true,"contexts":["Deep integration checks"]},"enforce_admins":true,"required_pull_request_reviews":null,"restrictions":null,"required_linear_history":true,"allow_force_pushes":false,"allow_deletions":false,"block_creations":false,"required_conversation_resolution":true}
EOF
    gh api --method PUT "repos/$repository/branches/main/protection" --input "$temporary"
    rm -f "$temporary"
    printf 'Configured labels and branch protection for %s\n' "$repository"
}

main() {
    [[ $# -gt 0 ]] || { usage; exit 1; }
    local command="$1"
    shift
    case "$command" in
        init) init "$@" ;;
        check) check "$@" ;;
        gh-setup) gh_setup "$@" ;;
        -h|--help|help) usage ;;
        *) fail "unknown command: $command" ;;
    esac
}

main "$@"
