#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
KIT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
readonly KIT_DIR
readonly TEMPLATE_DIR="$KIT_DIR/templates"
PUBLISH_TEMPORARY=""

usage() {
    cat <<'EOF'
Usage:
  project-workflow init --dir PATH [--languages rust,python,javascript] [--workflow-repository OWNER/REPO] [--workflow-ref TAG] [--with-codex]
  project-workflow check --dir PATH [--require-codex]
  project-workflow gh-setup --dir PATH [--repo OWNER/REPO] [--apply]
  project-workflow publish [--repo sophiaconsulting/agent-workflow] [--tag v1]

`init` creates only missing files. It never replaces an existing project file.
`check` validates the repository-local contract without running tests.
`gh-setup` prints the exact gh commands by default; --apply creates labels and
applies the branch-protection settings after you have reviewed them.
`publish` creates the shared GitHub repository as private, pushes this kit's
distribution files, and creates the immutable workflow tag.
EOF
}

fail() {
    printf 'project-workflow: %s\n' "$*" >&2
    exit 1
}

cleanup_publish() {
    if [[ -n "$PUBLISH_TEMPORARY" ]]; then
        rm -rf -- "$PUBLISH_TEMPORARY"
    fi
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || fail "required command not found: $1"
}

project_root() {
    git -C "$1" rev-parse --show-toplevel 2>/dev/null || fail "not a Git repository: $1"
}

copy_missing() {
    local source="$1"
    local destination="$2"
    if [[ -e "$destination" ]]; then
        printf 'kept existing %s\n' "$destination"
        return
    fi
    mkdir -p "$(dirname -- "$destination")"
    cp "$source" "$destination"
    printf 'created %s\n' "$destination"
}

ensure_policy_link() {
    local instruction_file="$1"
    local marker='# Agent workflow policy'
    if grep -Fqx "$marker" "$instruction_file" 2>/dev/null; then
        return
    fi
    printf '\n%s\nRead and follow `.agent-workflow/AGENT_WORKFLOW.md`; it defines the required Issue, worktree, PR, CI, and gh workflow for this project.\n' "$marker" >>"$instruction_file"
    printf 'added workflow policy link to %s\n' "$instruction_file"
}

render_missing() {
    local source="$1"
    local destination="$2"
    local repository="$3"
    local ref="$4"
    local languages="$5"
    local working_directory="$6"
    local recipe="$7"
    local temporary
    if [[ -e "$destination" ]]; then
        printf 'kept existing %s\n' "$destination"
        return
    fi
    mkdir -p "$(dirname -- "$destination")"
    temporary="$(mktemp)"
    sed \
        -e "s|__WORKFLOW_REPOSITORY__|$repository|g" \
        -e "s|__WORKFLOW_REF__|$ref|g" \
        -e "s|__LANGUAGES__|$languages|g" \
        -e "s|__WORKING_DIRECTORY__|$working_directory|g" \
        -e "s|__FAST_RECIPE__|$recipe|g" \
        -e "s|__DEEP_RECIPE__|$recipe|g" \
        "$source" >"$temporary"
    mv "$temporary" "$destination"
    printf 'created %s\n' "$destination"
}

init() {
    local directory=""
    local languages="rust"
    local workflow_repository="sophiaconsulting/agent-workflow"
    local workflow_ref="v1"
    local with_codex=false
    while (($#)); do
        case "$1" in
            --dir) directory="${2:-}"; shift 2 ;;
            --languages) languages="${2:-}"; shift 2 ;;
            --workflow-repository) workflow_repository="${2:-}"; shift 2 ;;
            --workflow-ref) workflow_ref="${2:-}"; shift 2 ;;
            --with-codex) with_codex=true; shift ;;
            *) fail "unknown init argument: $1" ;;
        esac
    done
    [[ -n "$directory" ]] || fail "init requires --dir PATH"
    [[ "$languages" =~ ^(rust|python|javascript)(,(rust|python|javascript))*$ ]] || fail "invalid --languages value: $languages"
    [[ "$workflow_repository" =~ ^[[:alnum:]_.-]+/[[:alnum:]_.-]+$ ]] || fail "invalid --workflow-repository value: $workflow_repository"
    [[ "$workflow_ref" =~ ^[[:alnum:]_.-]+$ ]] || fail "invalid --workflow-ref value: $workflow_ref"

    require_command git
    local root
    root="$(project_root "$directory")"
    copy_missing "$KIT_DIR/policy/AGENT_WORKFLOW.md" "$root/.agent-workflow/AGENT_WORKFLOW.md"
    copy_missing "$TEMPLATE_DIR/ci-manifest.yml" "$root/.agent-workflow/ci.yml"
    copy_missing "$TEMPLATE_DIR/CLAUDE.md" "$root/CLAUDE.md"
    ensure_policy_link "$root/CLAUDE.md"
    copy_missing "$TEMPLATE_DIR/pull_request_template.md" "$root/.github/pull_request_template.md"
    copy_missing "$TEMPLATE_DIR/issue_task.md" "$root/.github/ISSUE_TEMPLATE/agent-task.md"
    render_missing "$TEMPLATE_DIR/ci-fast.yml" "$root/.github/workflows/agent-fast.yml" "$workflow_repository" "$workflow_ref" "$languages" "." "ci-fast"
    render_missing "$TEMPLATE_DIR/ci-deep.yml" "$root/.github/workflows/agent-deep.yml" "$workflow_repository" "$workflow_ref" "$languages" "." "ci-deep"
    if [[ "$with_codex" == true ]]; then
        copy_missing "$TEMPLATE_DIR/AGENTS.md" "$root/AGENTS.md"
        ensure_policy_link "$root/AGENTS.md"
    fi
    printf "\nNext: add the required just recipes, run \`project-workflow check --dir %s\`, then review the Git diff.\n" "$root"
}

has_recipe() {
    local root="$1"
    local recipe="$2"
    (cd -- "$root" && just --list --unsorted 2>/dev/null) | awk '{print $1}' | grep -Fxq "$recipe"
}

check() {
    local directory=""
    local require_codex=false
    while (($#)); do
        case "$1" in
            --dir) directory="${2:-}"; shift 2 ;;
            --require-codex) require_codex=true; shift ;;
            *) fail "unknown check argument: $1" ;;
        esac
    done
    [[ -n "$directory" ]] || fail "check requires --dir PATH"
    require_command git
    local root
    local failed=false
    root="$(project_root "$directory")"
    local required_files=(
        "$root/CLAUDE.md"
        "$root/.agent-workflow/AGENT_WORKFLOW.md"
        "$root/.agent-workflow/ci.yml"
        "$root/.github/pull_request_template.md"
        "$root/.github/ISSUE_TEMPLATE/agent-task.md"
        "$root/.github/workflows/agent-fast.yml"
        "$root/.github/workflows/agent-deep.yml"
    )
    if [[ "$require_codex" == true ]]; then
        required_files+=("$root/AGENTS.md")
    fi
    local file
    for file in "${required_files[@]}"; do
        if [[ -f "$file" ]]; then
            printf 'ok file %s\n' "${file#"$root"/}"
        else
            printf 'missing file %s\n' "${file#"$root"/}" >&2
            failed=true
        fi
    done
    if command -v just >/dev/null 2>&1; then
        local recipe
        for recipe in fmt-check lint typecheck test-unit test-integration test-e2e build ci-fast ci-deep; do
            if has_recipe "$root" "$recipe"; then
                printf 'ok recipe %s\n' "$recipe"
            else
                printf 'missing recipe %s\n' "$recipe" >&2
                failed=true
            fi
        done
    else
        printf 'missing command just; recipes were not inspected\n' >&2
        failed=true
    fi
    [[ "$failed" == false ]] || exit 1
}

gh_setup() {
    local directory=""
    local repository=""
    local apply=false
    while (($#)); do
        case "$1" in
            --dir) directory="${2:-}"; shift 2 ;;
            --repo) repository="${2:-}"; shift 2 ;;
            --apply) apply=true; shift ;;
            *) fail "unknown gh-setup argument: $1" ;;
        esac
    done
    [[ -n "$directory" ]] || fail "gh-setup requires --dir PATH"
    require_command git
    require_command gh
    local root
    root="$(project_root "$directory")"
    if [[ -z "$repository" ]]; then
        repository="$(gh repo view --json nameWithOwner --jq .nameWithOwner -R "$root")"
    fi
    gh auth status >/dev/null || fail "GitHub CLI is not authenticated"
    if [[ "$apply" == false ]]; then
        cat <<EOF
Review and then run:
  project-workflow gh-setup --dir $root --repo $repository --apply

This will create/update the task labels and protect dev/main. It requires both
branches to exist. Required status checks are the names emitted by this kit's
reusable workflows: Project checks, Secret scan, Workflow lint, and Deep integration checks.
EOF
        return
    fi
    gh label create task --color 0E8A16 --description 'Agent-owned implementation task' --force -R "$repository"
    gh label create handoff --color 5319E7 --description 'Needs another session to continue' --force -R "$repository"
    gh label create blocked --color B60205 --description 'Blocked on an external decision or state' --force -R "$repository"
    local temporary
    temporary="$(mktemp)"
    cat >"$temporary" <<'EOF'
{"required_status_checks":{"strict":true,"contexts":["Project checks","Secret scan","Workflow lint"]},"enforce_admins":true,"required_pull_request_reviews":null,"restrictions":null,"required_linear_history":true,"allow_force_pushes":false,"allow_deletions":false,"block_creations":false,"required_conversation_resolution":true}
EOF
    gh api --method PUT "repos/$repository/branches/dev/protection" --input "$temporary"
    cat >"$temporary" <<'EOF'
{"required_status_checks":{"strict":true,"contexts":["Deep integration checks"]},"enforce_admins":true,"required_pull_request_reviews":null,"restrictions":null,"required_linear_history":true,"allow_force_pushes":false,"allow_deletions":false,"block_creations":false,"required_conversation_resolution":true}
EOF
    gh api --method PUT "repos/$repository/branches/main/protection" --input "$temporary"
    rm -f "$temporary"
    printf 'Configured labels and branch protection for %s\n' "$repository"
}

publish() {
    local repository="sophiaconsulting/agent-workflow"
    local tag="v1"
    while (($#)); do
        case "$1" in
            --repo) repository="${2:-}"; shift 2 ;;
            --tag) tag="${2:-}"; shift 2 ;;
            *) fail "unknown publish argument: $1" ;;
        esac
    done
    [[ "$repository" =~ ^sophiaconsulting/[[:alnum:]_.-]+$ ]] || fail "publish only supports a sophiaconsulting repository"
    [[ "$tag" =~ ^v[0-9]+([.][0-9]+)*$ ]] || fail "tag must be an immutable version such as v1 or v1.2"
    require_command gh
    require_command git
    gh auth status >/dev/null || fail "GitHub CLI is not authenticated; run gh auth login -h github.com"
    if gh repo view "$repository" >/dev/null 2>&1; then
        fail "remote repository already exists: $repository; refusing to overwrite it"
    fi
    PUBLISH_TEMPORARY="$(mktemp -d /private/tmp/agent-workflow-publish.XXXXXX)"
    trap cleanup_publish EXIT
    cp -R "$KIT_DIR/repository/." "$PUBLISH_TEMPORARY/"
    git -C "$PUBLISH_TEMPORARY" init -q -b main
    git -C "$PUBLISH_TEMPORARY" add .
    git -C "$PUBLISH_TEMPORARY" commit -qm "initial agent workflow kit"
    gh repo create "$repository" --private --source "$PUBLISH_TEMPORARY" --remote origin --push
    gh api --method PUT "repos/$repository/actions/permissions/access" -f access_level=organization
    git -C "$PUBLISH_TEMPORARY" tag -a "$tag" -m "Agent workflow $tag"
    git -C "$PUBLISH_TEMPORARY" push origin "$tag"
    [[ "$(gh repo view "$repository" --json isPrivate --jq .isPrivate)" == true ]] || fail "GitHub repository was not private: $repository"
    printf 'Published private workflow repository %s at %s with organization workflow access\n' "$repository" "$tag"
}

main() {
    [[ $# -gt 0 ]] || { usage; exit 1; }
    local command="$1"
    shift
    case "$command" in
        init) init "$@" ;;
        check) check "$@" ;;
        gh-setup) gh_setup "$@" ;;
        publish) publish "$@" ;;
        -h|--help|help) usage ;;
        *) fail "unknown command: $command" ;;
    esac
}

main "$@"
