{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "USE_BUILTIN_RIPGREP": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Bash(git push)",
      "Bash(git push:*)",
      "WebFetch",
      "WebSearch",
      "Skill(arewedone)",
      "Skill(db-search)",
      "Skill(design-principles)",
      "Skill(frontend-design)",
      "Skill(person-profiler)",
      "Skill(log-to-daily)",
      "Skill(media-manager)",
      "Skill(request)",
      "Skill(dotfiles-tweaker)",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "ExitPlanMode",
      "Read(//Volumes/external/**)",
      "Edit(//Volumes/external/**)"
    ],
    "deny": [],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Volumes/external"
    ]
  },
  "model": "opus[1m]",
  "autoMode": {
    "environment": [
      "$defaults",
      "The user's development directory is /Volumes/external/dev on an always-connected external volume, symlinked as ~/dev (so the same project appears as both /Users/vmasrani/dev/... and /Volumes/external/dev/...). Treat everything under /Volumes/external as the user's own project files -- equivalent to paths under the home directory, not untrusted, removable, or system locations."
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "/Volumes/external"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 ~/.claude/hooks/test_queue_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/.claude/hooks/post_tool_use.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/.claude/hooks/pre_compact.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "zsh ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": false,
    "frontend@mag-claude-plugins": false,
    "code-analysis@mag-claude-plugins": false,
    "orchestration@mag-claude-plugins": false,
    "pyright-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-wiggum@claude-plugins-official": false,
    "ralph-wiggum@claude-code-plugins": false,
    "commit-commands@claude-plugins-official": false,
    "claude-mem@thedotmack": false,
    "skill-creator@claude-plugins-official": true,
    "telegram@claude-plugins-official": false
  },
  "effortLevel": "xhigh",
  "fastMode": true,
  "showClearContextOnPlanAccept": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "preferredNotifChannel": "iterm2",
  "teammateMode": "tmux",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754286002006
  }
}
